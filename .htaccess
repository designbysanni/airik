# Clean URLs: airikart.com/work instead of airikart.com/work.html.
# Requires Apache mod_rewrite — true for Hostinger shared hosting by
# default. Nothing here needs a build step or touches the .html files
# themselves; it's purely a serving-layer rewrite.

RewriteEngine On

# Old slugs from before Revision Round 1 (renamed/removed 2026-07-20).
# Redirect rather than 404 — these may already be indexed by search
# engines or bookmarked from the first version of the site.
RewriteRule ^work/kinki-behavior/?$ /work/kinky-behavior [R=301,L,NC]
RewriteRule ^work/us-cellular/?$ /work [R=301,L,NC]
RewriteRule ^work/headshots/?$ /work [R=301,L,NC]
RewriteRule ^work/documentary/?$ /work/community [R=301,L,NC]

# work.html and the work/ folder (project detail pages) share the name
# "work" — Apache's own mod_dir would otherwise auto-redirect a bare
# /work request to /work/ (treating it as the directory) before rule 3
# below ever runs, since that directory genuinely exists. Turning this off
# means rule 3's ".html file exists" check always wins for the bare path,
# which is what we want: /work -> work.html, /work/<slug> -> work/<slug>.html.
DirectorySlash Off

# 1. Canonical redirect: anyone hitting /page.html directly (old bookmark,
#    external link, search engine that indexed it before this change) gets
#    a permanent redirect to the clean /page URL, so there's exactly one
#    canonical URL per page. Uses THE_REQUEST (the client's original
#    request line), not REQUEST_URI, so this can't loop with rule 3 below
#    even though rule 3 rewrites the same request internally afterward.
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 2. /index -> / (avoid a second canonical URL for the homepage existing).
RewriteRule ^index/?$ / [R=301,L]

# 3. Internally serve the real .html file for the extension-less request,
#    without changing what's in the browser's address bar. The .html file
#    takes priority even when a same-named directory also exists (see
#    DirectorySlash Off above) — deliberately no "!-d" (not-a-directory)
#    condition here for that reason.
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [NC,L]
